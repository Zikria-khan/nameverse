 ring-amber-100\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-lg font-semibold text-slate-900\",\"children\":[\"What does \",\"James\",\" mean?\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 leading-7\",\"children\":\"James is a male name from Biblical origin meaning \\\"Supplanter\\\". It is used in Christian naming contexts and appears in English, Hebrew, Greek, Latin. Pronunciation: JAYMZ. Lucky number: 3. James is sometimes associated with qualities such as Kind, Faithful in different cultural interpretations.\"}]]}]]}],\"$undefined\",[\"$\",\"section\",null,{\"className\":\"nv-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-5 flex items-start gap-3 text-slate-900\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-amber-700 shadow-sm\",\"children\":[\"$\",\"$L1a\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$5:props:children:props:children:props:children:5:props:children:props:children:0:props:children:0:props:children:2:props:children:1:props:children:props:iconNode\",\"className\":\"lucide-globe h-5 w-5\"}]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-xs font-semibold uppercase tracking-[0.18em] text-slate-500\",\"children\":\"Source Language\"}],[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Meaning in Greek\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-slate-500\",\"children\":\"Greek is used to show the source-language meaning and cultural nuance.\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"nv-card-solid p-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-2 flex items-center gap-2 text-sm font-semibold text-slate-900\",\"children\":[[\"$\",\"span\",null,{\"children\":\"$undefined\"}],[\"$\",\"span\",null,{\"children\":\"$undefined\"}]]}],[\"$\",\"p\",null,{\"className\":\"font-semibold text-slate-900\",\"children\":\"Ιακώβος\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text