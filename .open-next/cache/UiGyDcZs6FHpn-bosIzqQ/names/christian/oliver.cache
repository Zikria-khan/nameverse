 in the United States.\"}],[\"$\",\"div\",null,{\"className\":\"rounded-3xl bg-slate-50 p-4\",\"children\":\"The name Oliver carries a deep spiritual significance as it is derived from the olive tree, a symbol of peace and the presence of God in the Bible. This name can serve as a reminder of the spiritual values we should hold dear, such as peace, prosperity, and God’s presence in our lives. It can be a daily inspiration to live in harmony with others and to remain connected to the divine.\"}],\"$undefined\",\"$undefined\",false,[\"$\",\"p\",null,{\"className\":\"rounded-3xl bg-purple-50 p-4 text-sm text-purple-800\",\"children\":[\"Saint connection: \",\"Saint Oliver Plunkett\",\" — Saint Oliver Plunkett was an Irish martyr who was executed in 1681 for his faith. He is the patron saint of Ireland and is celebrated by the Catholic Church on July 1st.\"]}]]}]]}]\n2e:[\"$\",\"$L3d\",null,{\"className\":\"my-6\",\"minHeight\":\"90px\",\"instanceId\":\"name-detail-mid\"}]\n2f:[\"$\",\"section\",null,{\"className\":\"nv-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-5 flex items-start gap-3 text-slate-900\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-amber-700 shadow-sm\",\"children\":[\"$\",\"$L13\",null,{\"iconNode\":\"$22:props:children:props:children:1:props:children:0:props:children:1:props:children:0:props:children:1:props:children:0:props:iconNode\",\"className\":\"lucide-clock h-5 w-5\"}]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-xs font-semibold uppercase tracking-[0.18em] text-slate-500\",\"children\":\"Historical Usage\"}],[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Historical References\"}],\"$undefined\"]}]]}],[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",\"0\",{\"className\":\"rounded-3xl border border-slate-100 bg-slate-50 p-4\",\"children\":[[\"$\",\"p\",nu