,\"children\":\"Zain is a male name from Arabic origin meaning \\\"Giver of good\\\". It is used in Islamic naming contexts and appears in English, Urdu, Arabic, Hindi, Pashto. Pronunciation: ZAYN. Lucky number: 3. Zain is sometimes associated with qualities such as Kind, Just in different cultural interpretations.\"}]]}]]}],[\"$\",\"section\",null,{\"className\":\"nv-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-5 flex items-start gap-3 text-slate-900\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-amber-700 shadow-sm\",\"children\":[\"$\",\"$L1a\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"m5 8 6 6\",\"key\":\"1wu5hv\"}],[\"path\",{\"d\":\"m4 14 6-6 2-3\",\"key\":\"1k1g8d\"}],[\"path\",{\"d\":\"M2 5h12\",\"key\":\"or177f\"}],[\"path\",{\"d\":\"M7 2h1\",\"key\":\"1t2jsx\"}],[\"path\",{\"d\":\"m22 22-5-10-5 10\",\"key\":\"don7ne\"}],[\"path\",{\"d\":\"M14 18h6\",\"key\":\"1m8k6r\"}]],\"className\":\"lucide-languages h-5 w-5\"}]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-xs font-semibold uppercase tracking-[0.18em] text-slate-500\",\"children\":\"Translation\"}],[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Meaning in Urdu\"}],\"$undefined\"]}]]}],[\"$\",\"div\",null,{\"className\":\"nv-card-solid p-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-2 flex items-center gap-2 text-sm font-semibold text-slate-900\",\"children\":[[\"$\",\"span\",null,{\"children\":\"🇵🇰\"}],[\"$\",\"span\",null,{\"children\":\"Urdu\"}]]}],[\"$\",\"p\",null,{\"className\":\"font-semibold text-slate-900\",\"children\":\"زین\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm leading-6 text-slate-700\",\"children\":\"زین کا مطلب خوبصورتی اور جمال ہے\"}],null]}]]}],[\"$\",\"section\",null,{\"className\":\"nv-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-5 flex items-start gap-3 text-slate-