ef\":\"$undefined\",\"iconNode\":\"$5c:props:children:0:props:children:0:props:children:props:iconNode\",\"className\":\"lucide-shield h-5 w-5\"}]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-xs font-semibold uppercase tracking-[0.18em] text-slate-500\",\"children\":\"Cultural Context\"}],[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Cultural Significance\"}],\"$undefined\"]}]]}],[\"$\",\"div\",null,{\"className\":\"space-y-4 text-slate-700 leading-7\",\"children\":[[\"$\",\"div\",null,{\"className\":\"rounded-3xl bg-slate-50 p-4\",\"children\":\"The name Aadavan has a rich cultural background as it has been traditionally used in the Hindu community to denote the qualities of strength, courage, and invincibility. It is a name that resonates with the spirit of valor and the proud heritage of being a part of royal or warrior lineage.\"}],[\"$\",\"div\",null,{\"className\":\"rounded-3xl bg-slate-50 p-4\",\"children\":\"The name Aadavan holds deep spiritual significance as it is closely associated with the powerful Hindu deity Indra. The name carries the blessings of this god of rain, thunder, and power, signifying divine protection, strength, and a strong connection with the divine. The name Aadavan reminds us to be invincible not just in the material world but also in our spiritual journey through life.\"}],\"$undefined\",[\"$\",\"p\",null,{\"className\":\"rounded-3xl bg-amber-50 p-4 text-sm text-amber-800\",\"children\":[\"Cultural Hindu name\",\"\",\"\"]}],\"$undefined\",\"$undefined\"]}]]}]\n61:[\"$\",\"$L71\",null,{\"className\":\"my-6\",\"minHeight\":\"90px\",\"instanceId\":\"name-detail-mid\"}]\n62:[\"$\",\"section\",null,{\"className\":\"nv-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-5 flex items-start gap-3 text-slate-900\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-amber-700 shadow-sm\",\"child