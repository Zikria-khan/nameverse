adow-sm\",\"children\":[\"$\",\"$L1a\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$45:props:children:props:children:2:1:props:children:1:props:children:0:props:children:0:props:children:0:props:iconNode\",\"className\":\"lucide-book-open h-5 w-5\"}]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-xs font-semibold uppercase tracking-[0.18em] text-slate-500\",\"children\":\"Quick Answer\"}],[\"$\",\"h2\",null,{\"className\":\"text-xl font-semibold\",\"children\":\"Meaning Summary\"}],[\"$\",\"p\",null,{\"className\":\"mt-1 text-sm text-slate-500\",\"children\":\"A concise answer for featured snippets and voice search.\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"rounded-3xl bg-amber-50 p-5 text-slate-800 ring-1 ring-amber-100\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"text-lg font-semibold text-slate-900\",\"children\":[\"What does \",\"Aadavan\",\" mean?\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 leading-7\",\"children\":\"Aadavan is a male name from Sanskrit origin meaning \\\"Unconquered\\\". It is used in Hindu naming contexts and appears in Sanskrit, Hindi, Tamil, Telugu, Marathi, Bengali. Pronunciation: ah-dah-van. Lucky number: 7. Aadavan is sometimes associated with qualities such as Brave, Strong in different cultural interpretations.\"}]]}]]}],\"$undefined\",[\"$\",\"section\",null,{\"className\":\"nv-card\",\"children\":[[\"$\",\"div\",null,{\"className\":\"mb-5 flex items-start gap-3 text-slate-900\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-100 text-amber-700 shadow-sm\",\"children\":[\"$\",\"$L1a\",null,{\"ref\":\"$undefined\",\"iconNode\":\"$5:props:children:props:children:props:children:5:props:children:props:children:0:props:children:0:props:children:2:props:children:1:props:children:props:iconNode\",\"className\":\"lucide-globe h-5 w-5\"}]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"text-xs font-semi