{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/top-baby-names-usa/layout,_N_T_/top-baby-names-usa/page,_N_T_/top-baby-names-usa"},"segmentPaths":["/_tree","/_full","/top-baby-names-usa/__PAGE__","/top-baby-names-usa","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" dir=\"ltr\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=5, viewport-fit=cover\"/><link rel=\"preload\" href=\"/_next/static/media/03bda585a99c6450-s.p.0zzh68k1~whtc.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/f06bf9da926bae75-s.p.0pz0x0eczp58u.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0koxkjai0n-.h.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0ymwsvkbk0ib7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0t-9jsl_ol0fl.js\"/><script src=\"/_next/static/chunks/0pqt~8bl3ukh4.js\" async=\"\"></script><script src=\"/_next/static/chunks/0beb5ex4nim4n.js\" async=\"\"></script><script src=\"/_next/static/chunks/0m_p1bxtorv5i.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-07ftevsi35~lr.js\" async=\"\"></script><script src=\"/_next/static/chunks/0c766_vo2h8ka.js\" async=\"\"></script><script src=\"/_next/static/chunks/05y~n9sexur0m.js\" async=\"\"></script><script async=\"\" src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1510675468129183\" crossorigin=\"anonymous\"></script><script src=\"/_next/static/chunks/01xlw8hd842-c.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0go7ro5y.9fk7.js\" async=\"\"></script><script src=\"/_next/static/chunks/0ugf80l134~1n.js\" async=\"\"></script><meta name=\"color-scheme\" content=\"light dark\"/><meta name=\"application-name\" content=\"NameVerse\"/><meta property=\"og:site_name\" content=\"NameVerse\"/><meta name=\"content-language\" content=\"en\"/><meta name=\"theme-color\" content=\"#4F46E5\"/><meta name=\"mobile-web-app-capable\" content=\"yes\"/><meta name=\"google-site-verification\" content=\"iPU1wdP26kg58gDN3U4H39YuS20alsLvjfXRM-QtKLw\"/><meta name=\"apple-mobile-web-app-capable\" content=\"yes\"/><meta name=\"apple-mobile-web-app-title\" content=\"NameVerse\"/><meta name=\"apple-mobile-web-app-status-bar-style\" content=\"default\"/><meta name=\"msapplication-TileColor\" content=\"#4F46E5\"/><meta name=\"msapplication-TileImage\" content=\"/logo.png\"/><link rel=\"apple-touch-icon\" href=\"/logo.png\"/><link rel=\"manifest\" href=\"/manifest.json\"/><meta name=\"ahrefs-site-verification\" content=\"650afaf6635223ff618a281883a22b69b937a121e933b19907debeca67754cd4\"/><meta name=\"415fb3e376dd03499e3ea3cfd086272b2330a942\" content=\"415fb3e376dd03499e3ea3cfd086272b2330a942\"/><meta name=\"p:domain_verify\" content=\"2182ce49319a6b4ede3da073a469ce4a\"/><link rel=\"preconnect\" href=\"https://revolthem.com\"/><link rel=\"dns-prefetch\" href=\"https://revolthem.com\"/><link rel=\"dns-prefetch\" href=\"https://name-meaning-site-backend.vercel.app\"/><link rel=\"preconnect\" href=\"https://name-meaning-site-backend.vercel.app\" crossorigin=\"anonymous\"/><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><link rel=\"dns-prefetch\" href=\"https://www.clarity.ms\"/><link rel=\"preconnect\" href=\"https://www.clarity.ms\" crossorigin=\"anonymous\"/><link rel=\"prefetch\" href=\"/names/religion/islamic/1\" as=\"document\"/><link rel=\"prefetch\" href=\"/blog\" as=\"document\"/><link rel=\"icon\" type=\"image/png\" href=\"/logo.png\"/><link rel=\"shortcut icon\" type=\"image/png\" href=\"/logo.png\"/><meta name=\"googlebot\" content=\"index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1\"/><meta name=\"googlebot-news\" content=\"index, follow\"/><meta name=\"bingbot\" content=\"index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1\"/><meta name=\"yandex\" content=\"index, follow\"/><meta name=\"robots\" content=\"index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1\"/><link rel=\"alternate\" href=\"https://nameverse.vercel.app/sitemap.xml\" type=\"application/xml\" title=\"NameVerse Sitemap\"/><meta http-equiv=\"x-dns-prefetch-control\" content=\"on\"/><meta http-equiv=\"Accept-CH\" content=\"DPR, Width, Viewport-Width\"/><meta name=\"next-size-adjust\" content=\"\"/><meta name=\"theme-color\" content=\"#1E40AF\"/><title>Top 100 Baby Names in USA (2025 SSA Data) — Boys &amp; Girls | NameVerse</title><meta name=\"description\" content=\"The 50 most popular boy names and 50 most popular girl names in the U.S., ranked by real Social Security Administration data, with meanings, origins, and year-over-year trend for every name.\"/><link rel=\"author\" href=\"https://nameverse.vercel.app/about\"/><meta name=\"author\" content=\"NameVerse Editorial Team\"/><link rel=\"manifest\" href=\"/manifest.json\"/><meta name=\"keywords\" content=\"baby names, baby names 2026, islamic baby names, hindu baby names, christian baby names, quranic names, biblical names, sanskrit names, muslim baby names, baby name meanings, lucky numbers, baby name generator, name suggestions, trending baby names 2026, baby names with meanings, unique baby names, popular baby names, arabic names, urdu names\"/><meta name=\"creator\" content=\"NameVerse\"/><meta name=\"publisher\" content=\"NameVerse\"/><meta name=\"robots\" content=\"index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1\"/><meta name=\"category\" content=\"Baby Names, Culture, Religion\"/><meta name=\"classification\" content=\"Baby Name Dictionary &amp; Cultural Knowledge Base\"/><link rel=\"canonical\" href=\"https://nameverse.vercel.app/top-baby-names-usa\"/><meta property=\"og:title\" content=\"Top 100 Baby Names in USA (2025 SSA Data) — Boys &amp; Girls\"/><meta property=\"og:description\" content=\"The 50 most popular boy names and 50 most popular girl names in the U.S., ranked by real Social Security Administration data, with meanings, origins, and year-over-year trend for every name.\"/><meta property=\"og:url\" content=\"https://nameverse.vercel.app/top-baby-names-usa\"/><meta property=\"og:site_name\" content=\"NameVerse\"/><meta property=\"og:image\" content=\"https://nameverse.vercel.app/og/top-baby-names-usa.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:type\" content=\"article\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Top 100 Baby Names in USA (2025 SSA Data) — Boys &amp; Girls\"/><meta name=\"twitter:description\" content=\"The 50 most popular boy names and 50 most popular girl names in the U.S., ranked by real Social Security Administration data, with meanings, origins, and year-over-year trend for every name.\"/><meta name=\"twitter:image\" content=\"https://nameverse.vercel.app/og/top-baby-names-usa.png\"/><link rel=\"shortcut icon\" href=\"/favicon.ico\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\" sizes=\"any\"/><link rel=\"icon\" href=\"/icon.svg\" type=\"image/svg+xml\"/><link rel=\"icon\" href=\"/logo.png\" sizes=\"192x192\" type=\"image/png\"/><link rel=\"icon\" href=\"/logo.png\" sizes=\"512x512\" type=\"image/png\"/><link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\" sizes=\"180x180\" type=\"image/png\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"@id\":\"https://nameverse.vercel.app/#organization\",\"name\":\"NameVerse\",\"alternateName\":\"NameVerse — Cultural Name Knowledge Base\",\"url\":\"https://nameverse.vercel.app\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://nameverse.vercel.app/logo.png\",\"width\":192,\"height\":192},\"description\":\"NameVerse is a Cultural Name Knowledge Base and Multilingual Onomastics System for structured cultural and linguistic analysis of personal names across civilizations.\",\"sameAs\":[\"https://twitter.com/NameVerseOfficial\"],\"knowsAbout\":{\"@type\":\"Thing\",\"name\":\"Cultural Onomastics\",\"description\":\"Structured cultural and linguistic analysis of personal names across civilizations.\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"@id\":\"https://nameverse.vercel.app/#website\",\"name\":\"NameVerse\",\"alternateName\":\"NameVerse — Cultural Name Knowledge Base\",\"url\":\"https://nameverse.vercel.app\",\"description\":\"A structured cultural and linguistic knowledge graph for human names. Multilingual onomastics system for cross-cultural name research and analysis.\",\"publisher\":{\"@type\":\"Organization\",\"@id\":\"https://nameverse.vercel.app/#organization\"},\"inLanguage\":\"en-US\",\"about\":{\"@type\":\"Thing\",\"name\":\"Cultural Onomastics — Linguistic Name Analysis\",\"description\":\"Structured cultural and linguistic analysis of personal names across civilizations.\"},\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://nameverse.vercel.app/search?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://nameverse.vercel.app\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Baby Names\",\"item\":\"/names\"}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"CollectionPage\",\"name\":\"Popular Baby Names by Religion\",\"description\":\"Browse top baby names from different faiths — Muslim, Hindu, and Christian — with meanings and translations.\",\"url\":\"/names\",\"isPartOf\":{\"@type\":\"WebSite\",\"name\":\"NameVerse — Cultural Name Knowledge Base\",\"url\":\"https://nameverse.vercel.app\"},\"mainEntity\":{\"@type\":\"ItemList\",\"itemListElement\":[]}}</script><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"instrument_sans_f11a402-module__eb3qEq__variable fraunces_c34708e9-module__0Tq2Na__variable antialiased nv-body nv-page\"><div hidden=\"\"><!--$--><!--/$--></div><div id=\"temp-wrapper\"><!--$--><nav class=\"sticky top-0 z-[100] border-b border-slate-200 bg-white/90 backdrop-blur\"><div class=\"mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6\"><div class=\"h-8 w-28 rounded-full bg-slate-200\"></div><div class=\"hidden h-9 w-40 rounded-full bg-slate-200 lg:block\"></div></div></nav><!--/$--><div id=\"container-1606e7870f004d67136f85f2b1698cd3\"></div><div class=\"nv-route-chrome\"><div aria-hidden=\"true\" class=\"nv-route-ornament\"></div><div class=\"nv-route-content\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebPage\",\"name\":\"Top 100 Baby Names in USA (2025 SSA Data)\",\"url\":\"https://nameverse.vercel.app/top-baby-names-usa\",\"datePublished\":\"2026-05-08\",\"dateModified\":\"2026-05-08\",\"isPartOf\":{\"@type\":\"WebSite\",\"name\":\"NameVerse\",\"url\":\"https://nameverse.vercel.app\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"ItemList\",\"name\":\"Top 100 Baby Names in USA (2025)\",\"description\":\"Top 50 boy names and top 50 girl names in the U.S., ranked by Social Security Administration data.\",\"numberOfItems\":100,\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Liam\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Noah\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Oliver\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Elijah\"},{\"@type\":\"ListItem\",\"position\":5,\"name\":\"James\"},{\"@type\":\"ListItem\",\"position\":6,\"name\":\"Muhammad\"},{\"@type\":\"ListItem\",\"position\":7,\"name\":\"William\"},{\"@type\":\"ListItem\",\"position\":8,\"name\":\"Henry\"},{\"@type\":\"ListItem\",\"position\":9,\"name\":\"Lucas\"},{\"@type\":\"ListItem\",\"position\":10,\"name\":\"Benjamin\"},{\"@type\":\"ListItem\",\"position\":11,\"name\":\"Olivia\"},{\"@type\":\"ListItem\",\"position\":12,\"name\":\"Emma\"},{\"@type\":\"ListItem\",\"position\":13,\"name\":\"Charlotte\"},{\"@type\":\"ListItem\",\"position\":14,\"name\":\"Sophia\"},{\"@type\":\"ListItem\",\"position\":15,\"name\":\"Amelia\"},{\"@type\":\"ListItem\",\"position\":16,\"name\":\"Mia\"},{\"@type\":\"ListItem\",\"position\":17,\"name\":\"Isabella\"},{\"@type\":\"ListItem\",\"position\":18,\"name\":\"Evelyn\"},{\"@type\":\"ListItem\",\"position\":19,\"name\":\"Sofia\"},{\"@type\":\"ListItem\",\"position\":20,\"name\":\"Eliana\"}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is the most popular baby name in the USA right now?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Based on the Social Security Administration's most recent official data (2025 births, released May 2026), Liam is the top boy's name with 18,600 babies and Olivia is the top girl's name with 16,700 babies. It's Liam's ninth year in a row at #1 and Olivia's seventh.\"}},{\"@type\":\"Question\",\"name\":\"How does the Social Security Administration decide which names are most popular?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The SSA counts every Social Security card application filed for a newborn during the year. Since most parents apply for a card within the child's first year, this covers roughly 96% of all U.S. births, making it the most complete public source for name popularity.\"}},{\"@type\":\"Question\",\"name\":\"When does the SSA release the new baby names list each year?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The SSA publishes the list annually around Mother's Day (early-to-mid May) for births from the previous calendar year. The 2025 birth-year list was released on May 8, 2026.\"}},{\"@type\":\"Question\",\"name\":\"Are Sophia and Sofia counted as one name or two?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Two separate names. The SSA counts each exact spelling on the Social Security application separately, so Sophia, Sofia, Aiden and Ayden are each ranked on their own rather than combined.\"}},{\"@type\":\"Question\",\"name\":\"Which baby names are rising the fastest this year?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Comparing 2025 to 2024, the fastest-climbing names in the top 100 include Muhammad (up 3 spots) and Asher (up 5) among boys, and Meera (up 12) and Priya (up 9) among girls.\"}},{\"@type\":\"Question\",\"name\":\"Which popular names are losing ground?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Both Dylan and Maverick fell 13 spots each among boys' names from 2024 to 2025, and Luna dropped 14 spots among girls' names — one of the largest single-year declines in this year's top 100.\"}},{\"@type\":\"Question\",\"name\":\"Why isn't my state's most popular name showing up near the top?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"This list reflects national totals. Name popularity varies a lot by state and region — a name can be #5 in one state and outside the top 50 nationally. The SSA also publishes state-level breakdowns if you want to check a specific state.\"}},{\"@type\":\"Question\",\"name\":\"Does the top 100 list include every name given to babies in the U.S.?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. It only shows the 100 most common name spellings per gender. The SSA also excludes any name given to fewer than 5 babies nationally in a given year, to protect privacy — so thousands of rarer names given in 2025 simply don't appear in any public ranking.\"}},{\"@type\":\"Question\",\"name\":\"How many babies does the top 100 list actually represent?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The top 100 boy names cover 128,000 births and the top 100 girl names cover 119,000 births in 2025 — together representing just over 1.15 million of the roughly 3.6 million Social Security card applications filed for newborns that year.\"}},{\"@type\":\"Question\",\"name\":\"What's a 'combined' top 100 baby names list?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Since the SSA ranks boys' and girls' names separately (each with its own top 1000), a single 'Top 100 Baby Names' list is usually built by combining the top 50 boy names and top 50 girl names into one table, which is the format used on this page.\"}},{\"@type\":\"Question\",\"name\":\"Will next year's list look very different?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Usually not at the very top — the top 4–5 names in each gender tend to be stable year over year. Most of the real movement happens between roughly rank 20 and rank 100, where names can rise or fall by 10+ spots in a single year.\"}},{\"@type\":\"Question\",\"name\":\"Is a name 'popular' the same as a name 'trending'?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Not quite. Popular usually means high total volume (like Liam or Olivia, which have topped the list for years). Trending refers to year-over-year movement — a name like Cooper or Eloise can be trending up fast while still ranking outside the top 20 overall.\"}},{\"@type\":\"Question\",\"name\":\"Where can I see the full top 1,000 names, not just the top 100?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Social Security Administration publishes the complete top 1,000 names per gender, per year, along with historical data back to 1880, at ssa.gov/oact/babynames.\"}},{\"@type\":\"Question\",\"name\":\"Do unisex or gender-neutral names appear on this list?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The SSA tracks name counts separately by the sex recorded on each Social Security application, so a name like Riley appears once in the boys' list and once in the girls' list with two different ranks and birth counts, rather than as a single unisex entry.\"}}]}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://nameverse.vercel.app\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Top Baby Names USA\",\"item\":\"https://nameverse.vercel.app/top-baby-names-usa\"}]}</script><main class=\"tbn-page\"><nav aria-label=\"Breadcrumb\" class=\"breadcrumb\"><a href=\"/\">Home</a> <span aria-hidden=\"true\">/</span> <span>Top Baby Names USA</span></nav><header class=\"hero\"><p class=\"eyebrow\">Social Security Administration Data · <!-- -->2025<!-- --> Release</p><h1>The Top 100 Baby Names in the USA</h1><p class=\"hero-sub\">The 50 most popular boy names and 50 most popular girl names, straight from official U.S. Social Security records — with real meanings, origins, and year-over-year movement for every single name.</p><p class=\"meta-line\">Last updated <!-- -->May 8, 2026<!-- --> · <a href=\"#methodology\">How this list is built</a></p></header><section class=\"quick-answer\" aria-label=\"Quick answer\"><p><strong>Liam</strong> is the most popular boy&#x27;s name in the U.S. in <!-- -->2025<!-- -->, given to<!-- --> <!-- -->18,600<!-- --> newborns — its ninth year in a row at #1.<!-- --> <strong>Olivia</strong> is the most popular girl&#x27;s name, given to <!-- -->16,700<!-- --> <!-- -->newborns, its seventh consecutive year at the top. Both rankings come directly from Social Security card applications filed at birth.</p></section><section class=\"stats-row\" aria-label=\"Key statistics\"><div class=\"stat-card\"><span class=\"stat-label\">#1 Boy Name</span><span class=\"stat-value\">Liam</span><span class=\"stat-sub\">18,600<!-- --> births</span></div><div class=\"stat-card\"><span class=\"stat-label\">#1 Girl Name</span><span class=\"stat-value\">Olivia</span><span class=\"stat-sub\">16,700<!-- --> births</span></div><div class=\"stat-card\"><span class=\"stat-label\">Top 100 Boys Cover</span><span class=\"stat-value\">128,000</span><span class=\"stat-sub\">births in <!-- -->2025</span></div><div class=\"stat-card\"><span class=\"stat-label\">Top 100 Girls Cover</span><span class=\"stat-value\">119,000</span><span class=\"stat-sub\">births in <!-- -->2025</span></div></section><nav class=\"toc\" aria-label=\"Table of contents\"><a href=\"#movers\">Biggest Movers</a><a href=\"#top-boys\">Top 10 Boy Names</a><a href=\"#top-girls\">Top 10 Girl Names</a><a href=\"#full-list\">Full List of 100</a><a href=\"#methodology\">Methodology</a><a href=\"#faq\">FAQ</a></nav><section id=\"movers\" aria-labelledby=\"movers-h2\"><h2 id=\"movers-h2\">Biggest Movers: <!-- -->2025<!-- --> vs. <!-- -->2024</h2><p>Comparing this year&#x27;s SSA rankings against last year&#x27;s shows exactly which names are gaining momentum and which are cooling off, inside the top 100 for each gender.</p><div class=\"movers-grid\"><div class=\"movers-col\"><h3>Boys — Rising</h3><ul class=\"movers-list\"><li><span>Muhammad</span><span class=\"movers-delta up\">▲ <!-- -->3</span></li><li><span>Asher</span><span class=\"movers-delta up\">▲ <!-- -->5</span></li><li><span>Elias</span><span class=\"movers-delta up\">▲ <!-- -->7</span></li></ul></div><div class=\"movers-col\"><h3>Boys — Falling</h3><ul class=\"movers-list\"><li><span>Dylan</span><span class=\"movers-delta down\">▼ <!-- -->13</span></li><li><span>Maverick</span><span class=\"movers-delta down\">▼ <!-- -->13</span></li><li><span>Ryder</span><span class=\"movers-delta down\">▼ <!-- -->8</span></li></ul></div><div class=\"movers-col\"><h3>Girls — Rising</h3><ul class=\"movers-list\"><li><span>Ailany</span><span class=\"movers-delta up\">NEW</span></li><li><span>Meera</span><span class=\"movers-delta up\">▲ 12</span></li><li><span>Priya</span><span class=\"movers-delta up\">▲ 9</span></li></ul></div><div class=\"movers-col\"><h3>Girls — Falling</h3><ul class=\"movers-list\"><li><span>Luna</span><span class=\"movers-delta down\">▼ <!-- -->14</span></li><li><span>Cora</span><span class=\"movers-delta down\">▼ <!-- -->6</span></li><li><span>Riley</span><span class=\"movers-delta down\">▼ <!-- -->4</span></li></ul></div></div><p class=\"note\">Ailany is marked &quot;NEW&quot; because it wasn&#x27;t in the <!-- -->2024<!-- --> top 100 for girls at all — it entered the list for the first time this year.</p></section><section id=\"top-boys\" aria-labelledby=\"top-boys-h2\"><h2 id=\"top-boys-h2\">Top 10 Boy Names, In Depth</h2><div class=\"spotlight-grid\"><article class=\"spotlight-card\"><span class=\"spotlight-rank\">#<!-- -->1</span><h3>Liam</h3><p class=\"pronounce\">/<!-- -->LEE-um<!-- -->/</p><dl class=\"spotlight-facts\"><dt>Meaning</dt><dd>Strong-willed warrior</dd><dt>Origin</dt><dd>Irish</dd><dt>2025<!-- --> Births</dt><dd>18,600</dd><dt>Nicknames</dt><dd>Li, Lee</dd></dl></article><article class=\"spotlight-card\"><span class=\"spotlight-rank\">#<!-- -->2</span><h3>Noah</h3><p class=\"pronounce\">/<!-- -->NOH-uh<!-- -->/</p><dl class=\"spotlight-facts\"><dt>Meaning</dt><dd>Rest, comfort</dd><dt>Origin</dt><dd>Hebrew</dd><dt>2025<!-- --> Births</dt><dd>17,100</dd><dt>Nicknames</dt><dd>No, Noey</dd></dl></article><article class=\"spotlight-card\"><span class=\"spotlight-rank\">#<!-- -->3</span><h3>Oliver</h3><p class=\"pronounce\">/<!-- -->AH-liv-er<!-- -->/</p><dl class=\"spotlight-facts\"><dt>Meaning</dt><dd>Olive tree</