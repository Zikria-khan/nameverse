"a\",\"LinkedIn\",{\"href\":\"https://www.linkedin.com/\",\"target\":\"_blank\",\"rel\":\"noreferrer\",\"className\":\"grid h-10 w-10 place-items-center rounded-full border border-slate-200 text-slate-600 transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700\",\"aria-label\":\"LinkedIn\",\"children\":[\"$\",\"$L18\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2\",\"key\":\"975kel\"}],[\"circle\",{\"cx\":\"12\",\"cy\":\"7\",\"r\":\"4\",\"key\":\"17ys0d\"}]],\"className\":\"lucide-user h-4 w-4\"}]}]]}]]}],[[\"$\",\"div\",\"By Religion\",{\"children\":[[\"$\",\"h3\",null,{\"className\":\"mb-4 text-sm font-black uppercase tracking-[0.16em] text-slate-950\",\"children\":\"By Religion\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-3\",\"children\":[\"$L19\",\"$L1a\",\"$L1b\",\"$L1c\",\"$L1d\",\"$L1e\",\"$L1f\",\"$L20\",\"$L21\",\"$L22\",\"$L23\"]}]]}],\"$L24\",\"$L25\",\"$L26\"]]}],\"$L27\",\"$L28\"]}]}],\"$L29\"]}]}]}]\n6:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\n2a:T4e9,{\"@context\":\"https://schema.org\",\"@type\":\"ItemList\",\"name\":\"Top 100 Baby Names in USA (2025)\",\"description\":\"Top 50 boy names and top 50 girl names in the U.S., ranked by Social Security Administration data.\",\"numberOfItems\":100,\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Liam\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Noah\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Oliver\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Elijah\"},{\"@type\":\"ListItem\",\"position\":5,\"name\":\"James\"},{\"@type\":\"ListItem\",\"position\":6,\"name\":\"Muhammad\"},{\"@type\":\"ListItem\",\"position\":7,\"name\":\"William\"},{\"@type\":\"ListItem\",\"position\":8,\"name\":\"Henry\"},{\"@type\":\"ListItem\",\"position\":9,\"name\":\"Lucas\"},{\"@type\":\"ListItem\",\"position\":10,\"name\":\"Benjamin\"},{\"@type\":\"ListItem\",\"position\":11,\"name\":\"Olivia\"},{\"@type\":\"ListItem\",\"position\":12,\"name\":\"Emma\"},{\"@type\":\"ListItem\",\"position\":13,\"name\":\"Charlotte\"},{\"@type\":\"ListItem\",\"position\":14,\"name\":\"Sophia\"},{\"@type\":\"ListItem\",\"position\":15,\"name\":\"Amelia\"},{\"@type\":\"ListItem\",\"position\":16,\"name\":\"Mia\"},{\"@type\":\"ListItem\",\"position\":17,\"name\":\"Isabella\"},{\"@type\":\"ListItem\",\"position\":18,\"name\":\"Evelyn\"},{\"@type\":\"ListItem\",\"position\":19,\"name\":\"Sofia\"},{\"@type\":\"ListItem\",\"position\":20,\"name\":\"Eliana\"}]}2b:T13c4,{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is the most popular baby name in the USA right now?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Based on the Social Security Administration's most recent official data (2025 births, released May 2026), Liam is the top boy's name with 18,600 babies and Olivia is the top girl's name with 16,700 babies. It's Liam's ninth year in a row at #1 and Olivia's seventh.\"}},{\"@type\":\"Question\",\"name\":\"How does the Social Security Administration decide which names are most popular?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The SSA counts every Social Security card application filed for a newborn during the year. Since most parents apply for a card within the child's first year, this covers roughly 96% of all U.S. births, making it the most complete public source for name popularity.\"}},{\"@type\":\"Question\",\"name\":\"When does the SSA release the new baby names list each year?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The SSA publishes the list annually around Mother's Day (early-to-mid May) for births from the previous calendar year. The 2025 birth-year list was released on May 8, 2026.\"}},{\"@type\":\"Question\",\"name\":\"Are Sophia and Sofia counted as one name or two?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Two separate names. The SSA counts each exact spelling on the Social Security application separately, so Sophia, Sofia, Aiden and Ayden are each ranked on their own rather than combined.\"}},{\"@type\":\"Question\",\"name\":\"Which baby names are rising the fastest this year?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Comparing 2025 to 2024, the fastest-climbing names in the top 100 include Muhammad (up 3 spots) and Asher (up 5) among boys, and Meera (up 12) and Priya (up 9) among girls.\"}},{\"@type\":\"Question\",\"name\":\"Which popular names are losing ground?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Both Dylan and Maverick fell 13 spots each among boys' names from 2024 to 2025, and Luna dropped 14 spots among girls' names — one of the largest single-year declines in this year's top 100.\"}},{\"@type\":\"Question\",\"name\":\"Why isn't my state's most popular name showing up near the top?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"This list reflects national totals. Name popularity varies a lot by state and region — a name can be #5 in one state and outside the top 50 nationally. The SSA also publishes state-level breakdowns if you want to check a specific state.\"}},{\"@type\":\"Question\",\"name\":\"Does the top 100 list include every name given to babies in the U.S.?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No. It only shows the 100 most common name spellings per gender. The SSA also excludes any name given to fewer than 5 babies nationally in a given year, to protect privacy — so thousands of rarer names given in 2025 simply don't appear in any public ranking.\"}},{\"@type\":\"Question\",\"name\":\"How many babies does the top 100 list actually represent?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The top 100 boy names cover 128,000 births and the top 100 girl names cover 119,000 births in 2025 — together representing just over 1.15 million of the roughly 3.6 million Social Security card applications filed for newborns that year.\"}},{\"@type\":\"Question\",\"name\":\"What's a 'combined' top 100 baby names list?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Since the SSA ranks boys' and girls' names separately (each with its own top 1000), a single 'Top 100 Baby Names' list is usually built by combining the top 50 boy names and top 50 girl names into one table, which is the format used on this page.\"}},{\"@type\":\"Question\",\"name\":\"Will next year's list look very different?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Usually not at the very top — the top 4–5 names in each gender tend to be stable year over year. Most of the real movement happens between roughly rank 20 and rank 100, where names can rise or fall by 10+ spots in a single year.\"}},{\"@type\":\"Question\",\"name\":\"Is a name 'popular' the same as a name 'trending'?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Not quite. Popular usually means high total volume (like Liam or Olivia, which have topped the list for years). Trending refers to year-over-year movement — a name like Cooper or Eloise can be trending up fast while still ranking outside the top 20 overall.\"}},{\"@type\":\"Question\",\"name\":\"Where can I see the full top 1,000 names, not just the top 100?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Social Security Administration publishes the complete top 1,000 names per gender, per year, along with historical data back to 1880, at ssa.gov/oact/babynames.\"}},{\"@type\":\"Question\",\"name\":\"Do unisex or gender-neutral names appear on this list?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The SSA tracks name counts separately by the sex recorded on each Social Security application, so a name like Riley appears once in the boys' list and once in the girls' list with two different ranks and birth counts, rather than as a single unisex entry.\"}}]}7:[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"WebPage\\\",\\\"name\\\":\\\"Top 100 Baby Names in USA (2025 SSA Data)\\\",\\\"url\\\":\\\"https://nameverse.vercel.app/top-baby-names-usa\\\",\\\"datePublished\\\":\\\"2026-05-08\\\",\\\"dateModified\\\":\\\"2026-05-08\\\",\\\"isPartOf\\\":{\\\"@type\\\":\\\"WebSite\\\",\\\"name\\\":\\\"NameVerse\\\",\\\"url\\\":\\\"https://nameverse.vercel.app\\\"}}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$2a\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$2b\"}}],\"$L2c\",\"$L2d\"],[\"$L2e\"],\"$L2f\"]}]\n30:[]\n8:\"$W30\"\n9:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L31\",null,{\"children\":\"$L32\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L33\",null,{\"children\":[\"$\",\"$f\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L34\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\nb:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/0koxkjai0n-.h.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\nc:[\"$\",\"link\",\"1\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/0ymwsvkbk0ib7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n35:I[38353,[\"/_next/static/chunks/0c766_vo2h8ka.js\",\"/_next/static/chunks/05y~n9sexur0m.js\"],\"default\"]\n40:I[97367,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"OutletBoundary\"]\n19:[\"$\",\"li\",\"/islamic/boy-names\",{\"childre