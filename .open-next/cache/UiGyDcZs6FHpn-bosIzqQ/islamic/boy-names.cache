an means \\\"Peace\\\" - Hebrew/Arabic origin\"},{\"@type\":\"ListItem\",\"position\":20,\"name\":\"Imran\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#imran\",\"description\":\"Imran means \\\"Prosperity\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":21,\"name\":\"Hamza\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#hamza\",\"description\":\"Hamza means \\\"Lion\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":22,\"name\":\"Khalid\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#khalid\",\"description\":\"Khalid means \\\"Eternal\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":23,\"name\":\"Tariq\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#tariq\",\"description\":\"Tariq means \\\"Morning Star\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":24,\"name\":\"Faisal\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#faisal\",\"description\":\"Faisal means \\\"Decisive\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":25,\"name\":\"Salman\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#salman\",\"description\":\"Salman means \\\"Safe\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":26,\"name\":\"Zaid\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#zaid\",\"description\":\"Zaid means \\\"Growth\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":27,\"name\":\"Zain\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#zain\",\"description\":\"Zain means \\\"Beauty\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":28,\"name\":\"Rayyan\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#rayyan\",\"description\":\"Rayyan means \\\"Gate of Heaven\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":29,\"name\":\"Ayaan\",\"url\":\"https://nameverse.vercel.app/islamic/boy-names#ayaan\",\"description\":\"Ayaan means \\\"Gift of God\\\" - Arabic origin\"},{\"@type\":\"ListItem\",\"position\":30,\"n