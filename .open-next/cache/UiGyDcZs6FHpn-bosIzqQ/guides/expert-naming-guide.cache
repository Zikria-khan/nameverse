{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/guides/layout,_N_T_/guides/expert-naming-guide/layout,_N_T_/guides/expert-naming-guide/page,_N_T_/guides/expert-naming-guide"},"segmentPaths":["/_tree","/_full","/guides/expert-naming-guide/__PAGE__","/guides/expert-naming-guide","/guides","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" dir=\"ltr\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=5, viewport-fit=cover\"/><link rel=\"preload\" href=\"/_next/static/media/03bda585a99c6450-s.p.0zzh68k1~whtc.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/f06bf9da926bae75-s.p.0pz0x0eczp58u.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0koxkjai0n-.h.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0ymwsvkbk0ib7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0t-9jsl_ol0fl.js\"/><script src=\"/_next/static/chunks/0pqt~8bl3ukh4.js\" async=\"\"></script><script src=\"/_next/static/chunks/0beb5ex4nim4n.js\" async=\"\"></script><script src=\"/_next/static/chunks/0m_p1bxtorv5i.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-07ftevsi35~lr.js\" async=\"\"></script><script src=\"/_next/static/chunks/0c766_vo2h8ka.js\" async=\"\"></script><script src=\"/_next/static/chunks/05y~n9sexur0m.js\" async=\"\"></script><script async=\"\" src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1510675468129183\" crossorigin=\"anonymous\"></script><script src=\"/_next/static/chunks/01xlw8hd842-c.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0go7ro5y.9fk7.js\" async=\"\"></script