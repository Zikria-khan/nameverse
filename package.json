{
  "name": "nameverse-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npm run sitemap:build && next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "cf:build": "npm run sitemap:build && next build && npx opennextjs-cloudflare build",
    "cf:dev": "npx wrangler pages dev .open-next/assets",
    "ci:validate-slugs": "node scripts/ci-validate-slugs.js",
    "seo:validate": "node src/lib/seo/validation-suite.mjs",
    "sitemap:build": "node scripts/build-sitemap.js",
    "seo:audit": "npm run seo:validate && npm run sitemap:build",
    "clear-next-cache": "rimraf .next",
    "clear-all-cache": "rimraf .next node_modules/.cache",
    "dev:clean": "npm run clear-all-cache && next dev",
    "rebuild": "npm run clear-all-cache && next build",
    "reset": "npm run clear-all-cache && npm run dev"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.3",
    "@shadcn/ui": "^0.0.4",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^1.8.0",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hot-toast": "^2.4.1",
    "shadcn": "^2.10.0",
    "sitemap": "^9.0.0",
    "sonner": "^1.7.1",
    "swr": "^2.3.4",
    "tailwind-merge": "^3.3.1",
    "web-vitals": "^4.2.4",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.6",
    "wrangler": "^4.110.0"
  }
}
